@model IEnumerable<EventEase.Models.Event>
@{
    ViewData["Title"] = "Events";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h2 class="fw-bold mb-0"><i class="bi bi-stars text-purple me-2"></i>Events</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-2"></i>Add Event
    </a>
</div>

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-calendar-x fs-1 d-block mb-3"></i>
            <h5>No events yet</h5>
            <p>Add your first event to get started.</p>
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle me-2"></i>Add Event
            </a>
        </div>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var ev in Model)
        {
            <div class="col-sm-6 col-xl-4">
                <div class="card border-0 shadow-sm h-100 ee-entity-card">
                    <div class="ee-card-img-wrapper">
                        <img src="@ev.ImageUrl" class="card-img-top ee-card-img" alt="@ev.Name" />
                        <span class="badge bg-purple ee-badge-overlay">
                            @ev.StartDate.ToString("dd MMM yyyy")
                        </span>
                    </div>
                    <div class="card-body">
                        <h5 class="card-title fw-bold mb-1">@ev.Name</h5>
                        <p class="text-muted small mb-2">
                            <i class="bi bi-calendar-range me-1"></i>
                            @ev.StartDate.ToString("dd MMM yyyy") – @ev.EndDate.ToString("dd MMM yyyy")
                        </p>
                        <p class="text-muted small mb-2">
                            <i class="bi bi-clock me-1"></i>
                            Duration: @((ev.EndDate - ev.StartDate).Days) day(s)
                        </p>
                        @if (!string.IsNullOrWhiteSpace(ev.Description))
                        {
                            <p class="card-text small text-truncate-2">@ev.Description</p>
                        }
                    </div>
                    <div class="card-footer bg-transparent border-top d-flex gap-2">
                        <a asp-action="Details" asp-route-id="@ev.EventId" class="btn btn-sm btn-outline-primary flex-fill">
                            <i class="bi bi-eye me-1"></i>Details
                        </a>
                        <a asp-action="Edit" asp-route-id="@ev.EventId" class="btn btn-sm btn-outline-secondary flex-fill">
                            <i class="bi bi-pencil me-1"></i>Edit
                        </a>
                        <a asp-action="Delete" asp-route-id="@ev.EventId" class="btn btn-sm btn-outline-danger flex-fill">
                            <i class="bi bi-trash me-1"></i>Delete
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}
