@model EventEase.Models.Venue
@{
    ViewData["Title"] = Model.Name;
}

<div class="mb-3">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Back to Venues
    </a>
</div>

<div class="row g-4">
    <div class="col-md-5">
        <img src="@Model.ImageUrl" alt="@Model.Name" class="img-fluid rounded shadow-sm w-100" style="max-height:380px;object-fit:cover;" />
    </div>
    <div class="col-md-7">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body p-4">
                <div class="d-flex align-items-start justify-content-between mb-3">
                    <h3 class="fw-bold mb-0">@Model.Name</h3>
                    @if (Model.IsAvailable)
                    {
                        <span class="badge bg-success">Available</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Unavailable</span>
                    }
                </div>

                <dl class="row mb-3">
                    <dt class="col-sm-4 text-muted">Location</dt>
                    <dd class="col-sm-8"><i class="bi bi-geo-alt me-1"></i>@Model.Location</dd>

                    <dt class="col-sm-4 text-muted">Capacity</dt>
                    <dd class="col-sm-8"><i class="bi bi-people me-1"></i>@Model.Capacity.ToString("N0") persons</dd>

                    <dt class="col-sm-4 text-muted">Description</dt>
                    <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.Description) ? "—" : Model.Description)</dd>
                </dl>

                <div class="d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.VenueId" class="btn btn-primary btn-sm">
                        <i class="bi bi-pencil me-1"></i>Edit
                    </a>
                    <a asp-controller="Bookings" asp-action="Create" class="btn btn-success btn-sm">
                        <i class="bi bi-plus-circle me-1"></i>New Booking
                    </a>
                    <a asp-action="Delete" asp-route-id="@Model.VenueId" class="btn btn-outline-danger btn-sm ms-auto">
                        <i class="bi bi-trash me-1"></i>Delete
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Associated Bookings -->
<div class="card border-0 shadow-sm mt-4">
    <div class="card-header bg-transparent fw-semibold">
        <i class="bi bi-journal-check me-2 text-primary"></i>Bookings for this Venue (@Model.Bookings.Count)
    </div>
    <div class="card-body p-0">
        @if (!Model.Bookings.Any())
        {
            <div class="text-center py-4 text-muted">No bookings for this venue yet.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Reference</th>
                            <th>Event</th>
                            <th>Customer</th>
                            <th>Start</th>
                            <th>End</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var b in Model.Bookings)
                        {
                            <tr>
                                <td><span class="badge bg-primary">@b.BookingReference</span></td>
                                <td>@b.Event?.Name</td>
                                <td>@b.CustomerName</td>
                                <td>@b.StartDate.ToString("dd MMM yyyy")</td>
                                <td>@b.EndDate.ToString("dd MMM yyyy")</td>
                                <td>
                                    <a asp-controller="Bookings" asp-action="Details" asp-route-id="@b.BookingId"
                                       class="btn btn-sm btn-outline-secondary">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
