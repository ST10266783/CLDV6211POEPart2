@model EventEase.Models.Venue
@{
    ViewData["Title"] = "Edit Venue";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent fw-semibold fs-5 border-bottom">
                <i class="bi bi-pencil-square me-2 text-primary"></i>Edit Venue — @Model.Name
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <input asp-for="VenueId" type="hidden" />
                    <!-- Preserve existing image URL unless replaced -->
                    <input asp-for="ImageUrl" type="hidden" />

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-semibold"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Location" class="form-label fw-semibold"></label>
                        <input asp-for="Location" class="form-control" />
                        <span asp-validation-for="Location" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Capacity" class="form-label fw-semibold"></label>
                        <input asp-for="Capacity" class="form-control" type="number" min="1" />
                        <span asp-validation-for="Capacity" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-semibold"></label>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Current Image</label>
                        <div class="mb-2">
                            <img src="@Model.ImageUrl" alt="Current venue image" class="img-thumbnail ee-preview-img" />
                        </div>
                        <label asp-for="ImageFile" class="form-label fw-semibold">Replace Image</label>
                        <input type="file" name="imageFile" class="form-control" accept="image/*" />
                        <div class="form-text">Leave blank to keep the current image. Max 5 MB.</div>
                    </div>

                    <div class="mb-4">
                        <div class="form-check form-switch">
                            <input asp-for="IsAvailable" class="form-check-input" type="checkbox" role="switch" />
                            <label asp-for="IsAvailable" class="form-check-label fw-semibold">Available for Booking</label>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle me-2"></i>Save Changes
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-2"></i>Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
