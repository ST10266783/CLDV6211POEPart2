@model IEnumerable<EventEase.Models.Venue>
@{
    ViewData["Title"] = "Venues";
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h2 class="fw-bold mb-0"><i class="bi bi-building text-primary me-2"></i>Venues</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-2"></i>Add Venue
    </a>
</div>

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-building-x fs-1 d-block mb-3"></i>
            <h5>No venues yet</h5>
            <p>Add your first venue to get started.</p>
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle me-2"></i>Add Venue
            </a>
        </div>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var venue in Model)
        {
            <div class="col-sm-6 col-xl-4">
                <div class="card border-0 shadow-sm h-100 ee-entity-card">
                    <div class="ee-card-img-wrapper">
                        <img src="@venue.ImageUrl" class="card-img-top ee-card-img" alt="@venue.Name" />
                        @if (venue.IsAvailable)
                        {
                            <span class="badge bg-success ee-badge-overlay">Available</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary ee-badge-overlay">Unavailable</span>
                        }
                    </div>
                    <div class="card-body">
                        <h5 class="card-title fw-bold mb-1">@venue.Name</h5>
                        <p class="text-muted small mb-2">
                            <i class="bi bi-geo-alt me-1"></i>@venue.Location
                        </p>
                        <p class="text-muted small mb-3">
                            <i class="bi bi-people me-1"></i>Capacity: <strong>@venue.Capacity.ToString("N0")</strong> persons
                        </p>
                        @if (!string.IsNullOrWhiteSpace(venue.Description))
                        {
                            <p class="card-text small text-truncate-2">@venue.Description</p>
                        }
                    </div>
                    <div class="card-footer bg-transparent border-top d-flex gap-2">
                        <a asp-action="Details" asp-route-id="@venue.VenueId" class="btn btn-sm btn-outline-primary flex-fill">
                            <i class="bi bi-eye me-1"></i>Details
                        </a>
                        <a asp-action="Edit" asp-route-id="@venue.VenueId" class="btn btn-sm btn-outline-secondary flex-fill">
                            <i class="bi bi-pencil me-1"></i>Edit
                        </a>
                        <a asp-action="Delete" asp-route-id="@venue.VenueId" class="btn btn-sm btn-outline-danger flex-fill">
                            <i class="bi bi-trash me-1"></i>Delete
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}
