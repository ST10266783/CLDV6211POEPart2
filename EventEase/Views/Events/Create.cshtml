@model EventEase.Models.Event
@{
    ViewData["Title"] = "Add Event";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent fw-semibold fs-5 border-bottom">
                <i class="bi bi-calendar-plus me-2 text-primary"></i>Add New Event
            </div>
            <div class="card-body p-4">
                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-semibold"></label>
                        <input asp-for="Name" class="form-control" placeholder="e.g. Annual Gala Dinner" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-semibold"></label>
                        <textarea asp-for="Description" class="form-control" rows="3"
                                  placeholder="Optional — describe the event"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="StartDate" class="form-label fw-semibold"></label>
                            <input asp-for="StartDate" class="form-control" type="datetime-local" />
                            <span asp-validation-for="StartDate" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="EndDate" class="form-label fw-semibold"></label>
                            <input asp-for="EndDate" class="form-control" type="datetime-local" />
                            <span asp-validation-for="EndDate" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ImageFile" class="form-label fw-semibold"></label>
                        <input type="file" name="imageFile" class="form-control" accept="image/*" />
                        <div class="form-text">Accepted: JPEG, PNG, GIF, WebP — max 5 MB. Leave blank for a placeholder.</div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle me-2"></i>Create Event
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-2"></i>Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Auto-set EndDate when StartDate changes (defaults to +1 day)
    document.querySelector('[name="StartDate"]').addEventListener('change', function () {
        const end = document.querySelector('[name="EndDate"]');
        if (!end.value) {
            const d = new Date(this.value);
            d.setDate(d.getDate() + 1);
            end.value = d.toISOString().slice(0, 16);
        }
    });
</script>
}
