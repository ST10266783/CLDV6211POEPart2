@model EventEase.Models.ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 text-center">
        <div class="mb-4">
            <i class="bi bi-exclamation-octagon text-danger" style="font-size:5rem;"></i>
        </div>
        <h1 class="display-6 fw-bold text-danger">Oops! Something went wrong.</h1>
        <p class="text-muted mt-3">An unexpected error occurred while processing your request.</p>

        @if (Model.ShowRequestId)
        {
            <div class="alert alert-secondary mt-3 text-start">
                <strong>Request ID:</strong> <code>@Model.RequestId</code>
            </div>
        }

        <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-4">
            <i class="bi bi-house me-2"></i>Back to Dashboard
        </a>
    </div>
</div>
