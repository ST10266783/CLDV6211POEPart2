<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — EventEase</title>

    <!-- Bootstrap 5 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <!-- Site CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

<!-- ── Top Navigation ── -->
<nav class="navbar navbar-expand-lg navbar-dark ee-navbar shadow-sm">
    <div class="container-fluid px-4">
        <a class="navbar-brand fw-bold fs-4" asp-controller="Home" asp-action="Index">
            <i class="bi bi-calendar2-event-fill me-2 text-warning"></i>EventEase
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
                aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="mainNav">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0 ms-3 gap-1">
                <li class="nav-item">
                    <a class="nav-link px-3 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
                       asp-controller="Home" asp-action="Index">
                        <i class="bi bi-speedometer2 me-1"></i>Dashboard
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link px-3 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Venues" ? "active" : "")"
                       asp-controller="Venues" asp-action="Index">
                        <i class="bi bi-building me-1"></i>Venues
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link px-3 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Events" ? "active" : "")"
                       asp-controller="Events" asp-action="Index">
                        <i class="bi bi-stars me-1"></i>Events
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link px-3 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Bookings" ? "active" : "")"
                       asp-controller="Bookings" asp-action="Index">
                        <i class="bi bi-journal-check me-1"></i>Bookings
                    </a>
                </li>
            </ul>
            <span class="navbar-text text-muted small">
                <i class="bi bi-shield-lock me-1"></i>Booking Specialist Portal
            </span>
        </div>
    </div>
</nav>

<!-- ── Main Content ── -->
<main class="container-fluid px-4 mt-4 mb-5">
    <!-- Flash Messages -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show d-flex align-items-center gap-2 shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill fs-5"></i>
            <div>@TempData["Success"]</div>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center gap-2 shadow-sm" role="alert">
            <i class="bi bi-exclamation-triangle-fill fs-5"></i>
            <div>@TempData["Error"]</div>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Warning"] != null)
    {
        <div class="alert alert-warning alert-dismissible fade show d-flex align-items-center gap-2 shadow-sm" role="alert">
            <i class="bi bi-exclamation-circle-fill fs-5"></i>
            <div>@TempData["Warning"]</div>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @RenderBody()
</main>

<!-- ── Footer ── -->
<footer class="ee-footer py-3 mt-auto border-top">
    <div class="container-fluid px-4 d-flex justify-content-between align-items-center">
        <span class="text-muted small">
            <i class="bi bi-calendar2-event-fill text-warning me-1"></i>
            &copy; @DateTime.Now.Year EventEase — Internal Booking Portal
        </span>
        <span class="text-muted small">
            <i class="bi bi-database-fill me-1"></i>Local Storage &nbsp;|&nbsp;
            <i class="bi bi-cloud me-1"></i>Azurite Emulator
        </span>
    </div>
</footer>

<!-- Bootstrap 5 JS Bundle -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<!-- jQuery (needed for unobtrusive validation) -->
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@4.0.0/dist/jquery.validate.unobtrusive.min.js"></script>
<!-- Site JS -->
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
